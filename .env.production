# Прод-сборка (split-топология): клиентский бандл должен обращаться к API на
# api.brouhub.ru, а не на сам brouhub.ru (там /api нет). NEXT_PUBLIC_* — ПУБЛИЧНЫЕ
# значения (вшиваются в бандл), поэтому коммитятся намеренно.
# Грузится автоматически при `next build` / `next start` (NODE_ENV=production);
# в dev (`npm run dev`) НЕ применяется — там работает прокси /api → бэкенд.
NEXT_PUBLIC_API_BASE=https://api.brouhub.ru/api
